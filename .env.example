# ============================================================================
# Atom Support Vision — Environment Configuration
# Copy to `.env` and adjust. Docker Compose reads this file automatically.
# ============================================================================

# ---- General ----
NODE_ENV=development
TZ=UTC
PUBLIC_HOST=localhost                 # The hostname browsers use to reach the stack

# ---- Web (Next.js) ----
WEB_PORT=3000
# Leave EMPTY for the same-origin (Google-Meet) model — the browser uses the
# page origin and nginx routes /api, /socket.io/, /rtc/. Set to an absolute URL
# only when running the web app without nginx (advanced/dev).
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_MEDIA_WS_URL=
NEXT_PUBLIC_APP_NAME=Atom Support Vision

# ---- Backend (NestJS) ----
API_PORT=4000
API_GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# ---- Auth / Security ----
# Generate strong secrets in prod:  openssl rand -hex 64
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production_please_0001
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_in_production_please_0002
JWT_ACCESS_TTL=900           # seconds (15m)
JWT_REFRESH_TTL=604800       # seconds (7d)
INVITE_TOKEN_SECRET=dev_invite_secret_change_me_0003
INVITE_TOKEN_TTL=86400       # seconds (24h)
BCRYPT_ROUNDS=12
COOKIE_SECRET=dev_cookie_secret_change_me_0004
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=atom
POSTGRES_PASSWORD=atom_dev_password
POSTGRES_DB=atom_support
# FastAPI uses the async driver (+asyncpg); Alembic swaps to a sync driver internally.
DATABASE_URL=postgresql+asyncpg://atom:atom_dev_password@postgres:5432/atom_support

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ---- S3 / MinIO (object storage) ----
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=atom_minio
S3_SECRET_KEY=atom_minio_secret
S3_BUCKET_RECORDINGS=atom-recordings
S3_BUCKET_FILES=atom-files
S3_FORCE_PATH_STYLE=true

# ---- Media Server (mediasoup SFU) ----
MEDIA_PORT=5000                 # signaling http/ws port
# Empty = auto-detect LAN IP (same-machine / same-Wi-Fi). Set to the PUBLIC IP
# for internet joins. Never leave this as a loopback address for cross-device.
MEDIA_ANNOUNCED_IP=
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIA_NUM_WORKERS=2

# ---- TURN / STUN (NAT traversal, like Google Meet) ----
# Enable the bundled coturn for internet joins: TURN_URL=turn:<PUBLIC_IP>:3478
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_REALM=atom.local
TURN_USER=atom
TURN_PASS=atom_turn_secret
RECORDING_ENABLED=true
RECORDING_RTP_MIN_PORT=41000
RECORDING_RTP_MAX_PORT=41100

# ---- Live Speech-to-Text (self-hosted faster-whisper, in the media server) ----
STT_ENABLED=true
WHISPER_MODEL=base.en          # tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_DEVICE=cpu             # cpu | cuda
WHISPER_COMPUTE_TYPE=int8      # int8 (cpu) | float16 (gpu)
STT_RTP_MIN_PORT=42000
STT_RTP_MAX_PORT=42100

# ---- AI Session Assistant (optional; falls back to local heuristics if unset) ----
# Anthropic Claude powers transcription summary, sentiment, action items.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
AI_ASSISTANT_ENABLED=true

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAMESPACE=atom
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100

# ---- MinIO console ----
MINIO_CONSOLE_PORT=9001
