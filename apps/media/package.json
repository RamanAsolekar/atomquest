{
  "name": "@atom/media",
  "version": "1.0.0",
  "private": true,
  "description": "Atom Support Vision — mediasoup SFU media server (server-routed WebRTC + recording).",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart:dev": "npm --prefix ../../packages/shared run build",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "jest"
  },
  "dependencies": {
    "@atom/shared": "*",
    "@aws-sdk/client-s3": "^3.700.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.15.7",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": { "^@atom/shared$": "<rootDir>/../../packages/shared/src/index.ts" }
  }
}
